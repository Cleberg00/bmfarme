# Supabase PostgreSQL
# DATABASE_URL usa pgbouncer (pooling) — para queries
DATABASE_URL="postgres://postgres.[PROJECT-REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
# DATABASE_URL_NON_POOLING — para migrations (prisma migrate)
DATABASE_URL_NON_POOLING="postgres://postgres.[PROJECT-REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# CNPJ API
DATA_API_KEY=your-data-api-key

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ZONE_ZAPLIFYVALIDATION=915073a6e27e5dbd5ad6dab87915f2db
CLOUDFLARE_ZONE_BMSEVEN=aeb4d4611c8e17367efda08087908841
CLOUDFLARE_ZONE_ZAPLIFY01=c560c9a01e92ed6416e17d3c0a7aa3b6

# VPS
VPS_IP=your-vps-ip
VPS_SSH_USER=root
VPS_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----

# SMS24h
SMS24_API_KEY=your-sms24-api-key
SMS24_API_URL=http://api.sms24h.org/stubs/handler_api

# Frontend (Vercel)
VITE_API_URL=https://bmfarme.vercel.app
