generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_NON_POOLING")
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum SmsStatus {
  WAITING
  RECEIVED
  EXPIRED
  FAILED
}

enum BmStatus {
  ACTIVE
  SUSPENDED
  RESTRICTED
  DISABLED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(OPERATOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  clients    Client[]
  domains    Domain[]
  smsLogs    SmsLog[]
  bmAssets   BmAsset[]
  wabaAssets WabaAsset[]
}

model Client {
  id                 String    @id @default(cuid())
  cnpj               String    @unique
  razaoSocial        String
  nomeFantasia       String?
  endereco           String
  numero             String?
  complemento        String?
  bairro             String?
  cep                String
  municipio          String?
  uf                 String?
  situacao           String?
  dataSituacao       String?
  dataAbertura       String?
  porte              String?
  naturezaJuridica   String?
  atividadePrincipal String?
  telefone           String?
  email              String?
  userId             String
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  domains            Domain[]
  smsLogs            SmsLog[]
  bmAssets           BmAsset[]
}

model Domain {
  id                   String       @id @default(cuid())
  domainName           String
  cloudflareZoneId     String
  metaVerificationCode String
  status               DomainStatus @default(PENDING)
  clientId             String
  userId               String
  customRazao          String?
  baseDomain           String?
  templateIndex        Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @default(now()) @updatedAt
  client               Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  user                 User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  bmAssets             BmAsset[]

  @@unique([clientId, domainName])
}

model SmsLog {
  id          String    @id @default(cuid())
  phoneNumber String
  externalId  String?
  smsCode     String?
  provider    String
  status      SmsStatus @default(WAITING)
  clientId    String
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  bmAssets    BmAsset[]
}

enum WabaTier {
  TIER_1K
  TIER_10K
  TIER_100K
  UNLIMITED
}

enum WabaStatus {
  ACTIVE
  SUSPENDED
  FLAGGED
  UNKNOWN
}

model BmAsset {
  id          String      @id @default(cuid())
  bmId        String
  profileUsed String
  status      BmStatus    @default(ACTIVE)
  notes       String?
  clientId    String
  domainId    String
  smsLogId    String
  userId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  domain      Domain      @relation(fields: [domainId], references: [id], onDelete: Restrict)
  smsLog      SmsLog      @relation(fields: [smsLogId], references: [id], onDelete: Restrict)
  user        User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  wabaAssets  WabaAsset[]

  @@unique([clientId, bmId])
}

model WabaAsset {
  id          String     @id @default(cuid())
  wabaId      String     @unique
  displayName String
  tier        WabaTier   @default(TIER_1K)
  status      WabaStatus @default(ACTIVE)
  phoneNumber String?
  notes       String?
  bmAssetId   String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bmAsset     BmAsset?   @relation(fields: [bmAssetId], references: [id], onDelete: SetNull)
  user        User       @relation(fields: [userId], references: [id], onDelete: Restrict)
}
